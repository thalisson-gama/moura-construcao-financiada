# Long cache for fingerprintable static assets (we redeploy whole folder
# on every change, so the URLs effectively bust themselves on rebuild).
/assets/video/*
  Cache-Control: public, max-age=31536000, immutable

/assets/img/*
  Cache-Control: public, max-age=31536000, immutable

/assets/css/*
  Cache-Control: public, max-age=31536000, immutable

/assets/js/*
  Cache-Control: public, max-age=31536000, immutable

# HTML stays short-lived so a fresh deploy is visible immediately.
/*
  Cache-Control: public, max-age=300, must-revalidate
